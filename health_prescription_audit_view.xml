<tryton>
    <data noupdate="1">

        <!-- ======================================================= -->
        <!-- GROUP                                                     -->
        <!-- ======================================================= -->

        <record model="res.group" id="group_prescription_auditor">
            <field name="name">Prescription Auditor v3</field>
        </record>

    </data>
    <data>

        <!-- ======================================================= -->
        <!-- VIEWS: MedicationAudit list and form                     -->
        <!-- ======================================================= -->

        <record model="ir.ui.view" id="view_medication_audit_list">
            <field name="model">gnuhealth.medication.audit</field>
            <field name="name">medication_audit_list</field>
            <field name="type">tree</field>
        </record>

        <record model="ir.ui.view" id="view_medication_audit_form">
            <field name="model">gnuhealth.medication.audit</field>
            <field name="name">medication_audit_form</field>
            <field name="type">form</field>
        </record>

        <!-- ======================================================= -->
        <!-- ACTION WINDOW                                            -->
        <!-- ======================================================= -->

        <record model="ir.action.act_window" id="act_medication_audit">
            <field name="name">Medication Audit</field>
            <field name="res_model">gnuhealth.medication.audit</field>
        </record>

        <record model="ir.action.act_window.view" id="act_medication_audit_view_list">
            <field name="sequence" eval="10"/>
            <field name="view" ref="view_medication_audit_list"/>
            <field name="act_window" ref="act_medication_audit"/>
        </record>

        <record model="ir.action.act_window.view" id="act_medication_audit_view_form">
            <field name="sequence" eval="20"/>
            <field name="view" ref="view_medication_audit_form"/>
            <field name="act_window" ref="act_medication_audit"/>
        </record>

        <!-- ======================================================= -->
        <!-- MENU                                                      -->
        <!-- ======================================================= -->

        <menuitem name="Prescription Audit"
                  parent="health.gnuhealth_menu"
                  id="menu_prescription_audit"
                  sequence="50"
                  action="act_medication_audit"/>

        <record model="ir.ui.menu-res.group" id="menu_prescription_audit_group_access">
            <field name="menu" ref="menu_prescription_audit"/>
            <field name="group" ref="group_prescription_auditor"/>
        </record>

        <!-- ======================================================= -->
        <!-- MODEL ACCESS                                             -->
        <!-- ======================================================= -->

        <record model="ir.model.access" id="access_medication_audit_auditor">
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit')]"/>
            <field name="group" ref="group_prescription_auditor"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="False"/>
        </record>

        <record model="ir.model.access" id="access_select_start_auditor">
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit.select.start')]"/>
            <field name="group" ref="group_prescription_auditor"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="False"/>
        </record>

        <record model="ir.model.access" id="access_export_result_auditor">
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit.export.result')]"/>
            <field name="group" ref="group_prescription_auditor"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="False"/>
        </record>

        <!-- ======================================================= -->
        <!-- LOAD FROM PRESCRIPTION WIZARD                           -->
        <!-- ======================================================= -->

        <record model="ir.ui.view" id="view_select_prescription_start">
            <field name="model">gnuhealth.medication.audit.select.start</field>
            <field name="name">select_prescription_start</field>
            <field name="type">form</field>
        </record>

        <record model="ir.action.wizard" id="act_select_prescription_wizard">
            <field name="name">Cargar desde Receta</field>
            <field name="wiz_name">gnuhealth.medication.audit.select</field>
        </record>

        <!-- Make the wizard accessible from the list (tree) toolbar -->
        <record model="ir.action.keyword" id="keyword_load_prescription_tree">
            <field name="keyword">tree_action</field>
            <field name="action" ref="act_select_prescription_wizard"/>
            <field name="model">gnuhealth.medication.audit,-1</field>
        </record>

        <menuitem name="Cargar desde Receta"
                  parent="menu_prescription_audit"
                  id="menu_load_prescription"
                  sequence="10"
                  action="act_select_prescription_wizard"/>

        <record model="ir.ui.menu-res.group" id="menu_load_prescription_group_access">
            <field name="menu" ref="menu_load_prescription"/>
            <field name="group" ref="group_prescription_auditor"/>
        </record>

        <!-- ======================================================= -->
        <!-- EXPORT WIZARD                                            -->
        <!-- ======================================================= -->

        <record model="ir.ui.view" id="view_audit_export_result">
            <field name="model">gnuhealth.medication.audit.export.result</field>
            <field name="name">medication_audit_export</field>
            <field name="type">form</field>
        </record>

        <record model="ir.action.wizard" id="act_export_audit_wizard">
            <field name="name">Exportar a CSV</field>
            <field name="wiz_name">gnuhealth.medication.audit.export</field>
        </record>

        <record model="ir.action.keyword" id="keyword_export_audit">
            <field name="keyword">form_action</field>
            <field name="action" ref="act_export_audit_wizard"/>
            <field name="model">gnuhealth.medication.audit,-1</field>
        </record>

        <menuitem name="Exportar a CSV"
                  parent="menu_prescription_audit"
                  id="menu_export_audit_csv"
                  sequence="60"
                  action="act_export_audit_wizard"/>

        <record model="ir.ui.menu-res.group" id="menu_export_csv_group_access">
            <field name="menu" ref="menu_export_audit_csv"/>
            <field name="group" ref="group_prescription_auditor"/>
        </record>

        <!-- ======================================================= -->
        <!-- BUTTON RULES                                             -->
        <!-- ======================================================= -->

        <record model="ir.model.button" id="button_approve_line">
            <field name="name">approve_line</field>
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit')]"/>
        </record>
        <record model="ir.model.button.rule" id="rule_approve_line">
            <field name="button" ref="button_approve_line"/>
            <field name="group" ref="group_prescription_auditor"/>
        </record>

        <record model="ir.model.button" id="button_reject_line">
            <field name="name">reject_line</field>
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit')]"/>
        </record>
        <record model="ir.model.button.rule" id="rule_reject_line">
            <field name="button" ref="button_reject_line"/>
            <field name="group" ref="group_prescription_auditor"/>
        </record>

        <record model="ir.model.button" id="button_reset_line">
            <field name="name">reset_line</field>
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit')]"/>
        </record>
        <record model="ir.model.button.rule" id="rule_reset_line">
            <field name="button" ref="button_reset_line"/>
            <field name="group" ref="group_prescription_auditor"/>
        </record>

    </data>
</tryton>
