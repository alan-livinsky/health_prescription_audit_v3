<tryton>
    <data noupdate="1">

        <!-- ======================================================= -->
        <!-- GROUP                                                     -->
        <!-- ======================================================= -->

        <record model="res.group" id="group_prescription_auditor_v3">
            <field name="name">Prescription Auditor v3</field>
        </record>

    </data>
    <data>

        <!-- ======================================================= -->
        <!-- VIEWS: PrescriptionAuditImport (data entry)             -->
        <!-- ======================================================= -->

        <record model="ir.ui.view" id="view_prescription_audit_import_list_v3">
            <field name="model">gnuhealth.prescription.audit.import</field>
            <field name="name">prescription_audit_import_list</field>
            <field name="type">tree</field>
        </record>

        <record model="ir.ui.view" id="view_prescription_audit_import_form_v3">
            <field name="model">gnuhealth.prescription.audit.import</field>
            <field name="name">prescription_audit_import_form</field>
            <field name="type">form</field>
        </record>

        <!-- ======================================================= -->
        <!-- ACTION WINDOW: PrescriptionAuditImport                  -->
        <!-- ======================================================= -->

        <record model="ir.action.act_window" id="act_prescription_audit_import_v3">
            <field name="name">Cargar Receta</field>
            <field name="res_model">gnuhealth.prescription.audit.import</field>
        </record>

        <record model="ir.action.act_window.view" id="act_import_view_list_v3">
            <field name="sequence" eval="10"/>
            <field name="view" ref="view_prescription_audit_import_list_v3"/>
            <field name="act_window" ref="act_prescription_audit_import_v3"/>
        </record>

        <record model="ir.action.act_window.view" id="act_import_view_form_v3">
            <field name="sequence" eval="20"/>
            <field name="view" ref="view_prescription_audit_import_form_v3"/>
            <field name="act_window" ref="act_prescription_audit_import_v3"/>
        </record>

        <!-- ======================================================= -->
        <!-- VIEWS: MedicationAudit (auditing)                       -->
        <!-- ======================================================= -->

        <record model="ir.ui.view" id="view_medication_audit_list_v3">
            <field name="model">gnuhealth.medication.audit</field>
            <field name="name">medication_audit_list</field>
            <field name="type">tree</field>
        </record>

        <record model="ir.ui.view" id="view_medication_audit_form_v3">
            <field name="model">gnuhealth.medication.audit</field>
            <field name="name">medication_audit_form</field>
            <field name="type">form</field>
        </record>

        <!-- ======================================================= -->
        <!-- ACTION WINDOW: MedicationAudit                          -->
        <!-- ======================================================= -->

        <record model="ir.action.act_window" id="act_medication_audit_v3">
            <field name="name">Auditoría de Medicamentos</field>
            <field name="res_model">gnuhealth.medication.audit</field>
        </record>

        <record model="ir.action.act_window.view" id="act_medication_audit_view_list_v3">
            <field name="sequence" eval="10"/>
            <field name="view" ref="view_medication_audit_list_v3"/>
            <field name="act_window" ref="act_medication_audit_v3"/>
        </record>

        <record model="ir.action.act_window.view" id="act_medication_audit_view_form_v3">
            <field name="sequence" eval="20"/>
            <field name="view" ref="view_medication_audit_form_v3"/>
            <field name="act_window" ref="act_medication_audit_v3"/>
        </record>

        <!-- ======================================================= -->
        <!-- MENU                                                      -->
        <!-- ======================================================= -->

        <menuitem name="Prescription Audit v3"
                  parent="health.gnuhealth_menu"
                  id="menu_prescription_audit_v3"
                  sequence="50"/>

        <record model="ir.ui.menu-res.group" id="menu_prescription_audit_group_access_v3">
            <field name="menu" ref="menu_prescription_audit_v3"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
        </record>

        <menuitem name="Cargar Receta"
                  parent="menu_prescription_audit_v3"
                  id="menu_load_prescription_v3"
                  sequence="10"
                  action="act_prescription_audit_import_v3"/>

        <record model="ir.ui.menu-res.group" id="menu_load_prescription_group_access_v3">
            <field name="menu" ref="menu_load_prescription_v3"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
        </record>

        <menuitem name="Auditoría de Medicamentos"
                  parent="menu_prescription_audit_v3"
                  id="menu_medication_audit_v3"
                  sequence="20"
                  action="act_medication_audit_v3"/>

        <record model="ir.ui.menu-res.group" id="menu_medication_audit_group_access_v3">
            <field name="menu" ref="menu_medication_audit_v3"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
        </record>

        <!-- ======================================================= -->
        <!-- MODEL ACCESS                                             -->
        <!-- ======================================================= -->

        <record model="ir.model.access" id="access_prescription_audit_import_auditor_v3">
            <field name="model" search="[('model', '=', 'gnuhealth.prescription.audit.import')]"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="False"/>
        </record>

        <record model="ir.model.access" id="access_medication_audit_auditor_v3">
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit')]"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="False"/>
        </record>

        <record model="ir.model.access" id="access_export_result_auditor_v3">
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit.export.result')]"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_delete" eval="False"/>
        </record>

        <!-- ======================================================= -->
        <!-- EXPORT WIZARD                                            -->
        <!-- ======================================================= -->

        <record model="ir.ui.view" id="view_audit_export_result_v3">
            <field name="model">gnuhealth.medication.audit.export.result</field>
            <field name="name">medication_audit_export</field>
            <field name="type">form</field>
        </record>

        <record model="ir.action.wizard" id="act_export_audit_wizard_v3">
            <field name="name">Exportar a CSV</field>
            <field name="wiz_name">gnuhealth.medication.audit.export</field>
        </record>

        <record model="ir.action.keyword" id="keyword_export_audit_v3">
            <field name="keyword">form_action</field>
            <field name="action" ref="act_export_audit_wizard_v3"/>
            <field name="model">gnuhealth.medication.audit,-1</field>
        </record>

        <menuitem name="Exportar a CSV"
                  parent="menu_prescription_audit_v3"
                  id="menu_export_audit_csv_v3"
                  sequence="60"
                  action="act_export_audit_wizard_v3"/>

        <record model="ir.ui.menu-res.group" id="menu_export_csv_group_access_v3">
            <field name="menu" ref="menu_export_audit_csv_v3"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
        </record>

        <!-- ======================================================= -->
        <!-- BUTTON RULES                                             -->
        <!-- ======================================================= -->

        <record model="ir.model.button" id="button_confirm_import_v3">
            <field name="name">confirm_import</field>
            <field name="model" search="[('model', '=', 'gnuhealth.prescription.audit.import')]"/>
        </record>
        <record model="ir.model.button.rule" id="rule_confirm_import_v3">
            <field name="button" ref="button_confirm_import_v3"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
        </record>

        <record model="ir.model.button" id="button_approve_line_v3">
            <field name="name">approve_line</field>
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit')]"/>
        </record>
        <record model="ir.model.button.rule" id="rule_approve_line_v3">
            <field name="button" ref="button_approve_line_v3"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
        </record>

        <record model="ir.model.button" id="button_reject_line_v3">
            <field name="name">reject_line</field>
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit')]"/>
        </record>
        <record model="ir.model.button.rule" id="rule_reject_line_v3">
            <field name="button" ref="button_reject_line_v3"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
        </record>

        <record model="ir.model.button" id="button_reset_line_v3">
            <field name="name">reset_line</field>
            <field name="model" search="[('model', '=', 'gnuhealth.medication.audit')]"/>
        </record>
        <record model="ir.model.button.rule" id="rule_reset_line_v3">
            <field name="button" ref="button_reset_line_v3"/>
            <field name="group" ref="group_prescription_auditor_v3"/>
        </record>

    </data>
</tryton>
