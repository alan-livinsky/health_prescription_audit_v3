<?xml version="1.0"?>
<form create="0" delete="0">
    <label name="source_prescription"
           states="{'invisible': Bool(Eval('prescription_line', False))}"
           depends="['prescription_line']"/>
    <field name="source_prescription" colspan="3"
           states="{'invisible': Bool(Eval('prescription_line', False))}"
           depends="['prescription_line']"/>
    <group string="Contexto" colspan="4" col="4" id="group_context">
        <field name="prescription" string="Receta" colspan="2"
               states="{'invisible': Not(Bool(Eval('prescription_line', False)))}"
               depends="['prescription_line']"/>
        <field name="patient" colspan="2"
               states="{'invisible': Not(Bool(Eval('prescription_line', False)))}"
               depends="['prescription_line']"/>
        <field name="medicament" colspan="2"
               states="{'invisible': Not(Bool(Eval('prescription_line', False)))}"
               depends="['prescription_line']"/>
    </group>
    <separator id="sep_audit" colspan="4"/>
    <group string="Estado Auditoría" colspan="4" col="2" id="group_audit_status">
        <label name="audit_state"/>
        <field name="audit_state" string="Estado"/>
        <label name="audit_date"/>
        <field name="audit_date" string="Fecha Auditoría"/>
        <label name="audit_user"/>
        <field name="audit_user" string="Auditor"/>
    </group>
    <group string="Acciones" colspan="4" col="3" id="group_audit_actions">
        <button name="approve_line"
                string="Aceptar"
                icon="tryton-ok"
                help="Aprobar este medicamento"/>
        <button name="reject_line"
                string="Rechazar"
                icon="tryton-cancel"
                help="Rechazar este medicamento"/>
        <button name="reset_line"
                string="Restablecer"
                icon="tryton-refresh"
                help="Restablecer auditoría a pendiente"
                states="{'invisible': Not(Eval('is_audit_overseer', False))}"
                depends="['is_audit_overseer']"/>
    </group>
    <field name="audit_notes" string="Notas" colspan="4"/>
</form>
